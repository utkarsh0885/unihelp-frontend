# ┌──────────────────────────────────────────────────────────────────────────────┐
# │ UniHelp Backend – Environment Variables                                     │
# │                                                                             │
# │ Copy this file as .env and fill in the values.                             │
# │ All variables are REQUIRED unless marked [Optional].                        │
# │                                                                             │
# │ For Render: Set these in Dashboard → Environment tab.                      │
# └──────────────────────────────────────────────────────────────────────────────┘

# ── MongoDB Atlas ──────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/unihelp?retryWrites=true&w=majority

# ── JWT Authentication ─────────────────────────────────────────────────────────
JWT_SECRET=<random-64-char-string>              # openssl rand -hex 32
JWT_REFRESH_SECRET=<random-64-char-string>      # openssl rand -hex 32

# ── Express Session ────────────────────────────────────────────────────────────
SESSION_SECRET=<random-64-char-string>          # openssl rand -hex 32

# ── Google OAuth 2.0 ──────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=<your-client-id>.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=<your-client-secret>
GOOGLE_CALLBACK_URL=https://unihelp-backend-a5f3.onrender.com/auth/google/callback

# ── Frontend URL (for CORS) ───────────────────────────────────────────────────
FRONTEND_URL=https://unihelp.vercel.app

# ── Server ─────────────────────────────────────────────────────────────────────
PORT=3000                                       # [Optional] Default: 3000
NODE_ENV=production                             # [Optional] Default: development
BASE_URL=https://unihelp-backend-a5f3.onrender.com  # [Optional] Used for keep-alive
