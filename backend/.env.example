# ┌──────────────────────────────────────────────────────────────────────────────┐
# │ UniHelp Backend – Environment Variables                                     │
# │                                                                             │
# │ Copy this file as .env and fill in the values.                             │
# │ ALL variables below are REQUIRED — the server will NOT start without them. │
# │                                                                             │
# │ For Render: Set these in Dashboard → Environment tab.                      │
# │                                                                             │
# │ ⚠️  NEVER commit your .env file to git!                                    │
# │ ⚠️  Secrets must be ≥ 16 characters (enforced at startup).                 │
# └──────────────────────────────────────────────────────────────────────────────┘

# ── JWT Authentication ─────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=<paste-64-char-hex-string-here>
JWT_REFRESH_SECRET=<paste-64-char-hex-string-here>

# ── Express Session ────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SESSION_SECRET=<paste-64-char-hex-string-here>

# ── Google OAuth 2.0 ──────────────────────────────────────────────────────────
# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=<your-client-id>.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=<your-client-secret>
GOOGLE_CALLBACK_URL=https://unihelp-backend-a5f3.onrender.com/auth/google/callback

# ── Frontend URL (for CORS + OAuth redirects) ─────────────────────────────────
FRONTEND_URL=https://unihelp.vercel.app

# ── Server (Optional) ─────────────────────────────────────────────────────────
# PORT=3000                                       # Default: 3000
# NODE_ENV=production                             # Default: development
# BASE_URL=https://unihelp-backend-a5f3.onrender.com  # Used for keep-alive ping
